---
import MainLayout from "../layouts/MainLayout.astro";

// Get error details from URL params or default values
const url = Astro.url;
const errorCode = url.searchParams.get("code") || "500";
const errorMessage = url.searchParams.get("message") || "Something went wrong";
const errorDetails = url.searchParams.get("details") || "An unexpected error occurred. Please try again later.";

// Map error codes to user-friendly titles
const errorTitles: Record<string, string> = {
  "400": "Bad Request",
  "401": "Unauthorized",
  "403": "Forbidden",
  "404": "Not Found",
  "500": "Internal Server Error",
  "502": "Bad Gateway",
  "503": "Service Unavailable",
};

const errorTitle = errorTitles[errorCode] || "Error";
---

<MainLayout title={`${errorTitle} - QR Scanner Registry`} showNavigation={false}>
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="max-w-md mx-auto text-center">
      <div class="mb-8">
        <!-- Error Illustration -->
        <div
          class="w-32 h-32 mx-auto mb-6 bg-gradient-to-br from-destructive/20 to-orange-500/20 rounded-full flex items-center justify-center"
        >
          <svg class="w-16 h-16 text-destructive" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
            ></path>
          </svg>
        </div>

        <h1 class="text-6xl font-bold text-foreground mb-4">{errorCode}</h1>
        <h2 class="text-2xl font-semibold text-foreground mb-4">{errorTitle}</h2>
        <p class="text-lg text-muted-foreground mb-2">{errorMessage}</p>
        <p class="text-sm text-muted-foreground mb-8">{errorDetails}</p>
      </div>

      <!-- Error-specific guidance -->
      {
        errorCode === "401" && (
          <div class="bg-muted/50 rounded-lg p-4 mb-6">
            <p class="text-sm text-muted-foreground">
              You need to sign in to access this resource. Please log in with your Google account.
            </p>
          </div>
        )
      }

      {
        errorCode === "403" && (
          <div class="bg-muted/50 rounded-lg p-4 mb-6">
            <p class="text-sm text-muted-foreground">
              You don't have permission to access this resource. Please check your account permissions.
            </p>
          </div>
        )
      }

      {
        errorCode === "500" && (
          <div class="bg-muted/50 rounded-lg p-4 mb-6">
            <p class="text-sm text-muted-foreground">
              Our servers are experiencing issues. Please try again in a few minutes.
            </p>
          </div>
        )
      }

      {
        errorCode === "503" && (
          <div class="bg-muted/50 rounded-lg p-4 mb-6">
            <p class="text-sm text-muted-foreground">
              The service is temporarily unavailable. We're working to restore it as quickly as possible.
            </p>
          </div>
        )
      }

      <!-- Action Buttons -->
      <div class="space-y-4">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-6 py-2 w-full"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
            ></path>
          </svg>
          Go to Home
        </a>

        <button
          onclick="window.location.reload()"
          class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 px-6 py-2 w-full"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
            ></path>
          </svg>
          Try Again
        </button>

        <button
          onclick="history.back()"
          class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-foreground h-10 px-4 py-2 w-full"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"
            ></path>
          </svg>
          Go Back
        </button>
      </div>

      <!-- Help Text -->
      <div class="mt-8 pt-8 border-t">
        <p class="text-sm text-muted-foreground">
          If this problem persists, please contact support with error code {errorCode}.
        </p>
      </div>
    </div>
  </div>
</MainLayout>
