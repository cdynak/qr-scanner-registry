---
import MainLayout from "../layouts/MainLayout.astro";
import { AuthGuard } from "../components/AuthGuard";
import { QRScanner } from "../components/QRScanner";
import { LoginButton } from "../components/LoginButton";
---

<MainLayout title="QR Scanner Registry - Scanner">
  <div class="container mx-auto px-4 py-8">
    <AuthGuard client:load>
      <!-- Authenticated User Content -->
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-8">
          <h1 class="text-3xl font-bold text-foreground mb-4">QR & Barcode Scanner</h1>
          <p class="text-muted-foreground">Position a QR code or barcode in front of your camera to scan it</p>
        </div>

        <!-- Scanner Component -->
        <div class="bg-card rounded-lg border shadow-sm overflow-hidden">
          <QRScanner client:load />
        </div>

        <!-- Instructions -->
        <div class="mt-8 bg-muted/50 rounded-lg p-6">
          <h3 class="text-lg font-semibold mb-4 flex items-center">
            <svg class="w-5 h-5 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            How to Scan
          </h3>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="space-y-3">
              <div class="flex items-start space-x-3">
                <div
                  class="w-6 h-6 bg-primary text-primary-foreground rounded-full flex items-center justify-center text-sm font-semibold flex-shrink-0 mt-0.5"
                >
                  1
                </div>
                <div>
                  <h4 class="font-medium">Allow Camera Access</h4>
                  <p class="text-sm text-muted-foreground">Grant permission when prompted to use your camera</p>
                </div>
              </div>
              <div class="flex items-start space-x-3">
                <div
                  class="w-6 h-6 bg-primary text-primary-foreground rounded-full flex items-center justify-center text-sm font-semibold flex-shrink-0 mt-0.5"
                >
                  2
                </div>
                <div>
                  <h4 class="font-medium">Position the Code</h4>
                  <p class="text-sm text-muted-foreground">
                    Hold your device steady and center the code in the viewfinder
                  </p>
                </div>
              </div>
            </div>
            <div class="space-y-3">
              <div class="flex items-start space-x-3">
                <div
                  class="w-6 h-6 bg-primary text-primary-foreground rounded-full flex items-center justify-center text-sm font-semibold flex-shrink-0 mt-0.5"
                >
                  3
                </div>
                <div>
                  <h4 class="font-medium">Wait for Detection</h4>
                  <p class="text-sm text-muted-foreground">The scanner will automatically detect and decode the code</p>
                </div>
              </div>
              <div class="flex items-start space-x-3">
                <div
                  class="w-6 h-6 bg-primary text-primary-foreground rounded-full flex items-center justify-center text-sm font-semibold flex-shrink-0 mt-0.5"
                >
                  4
                </div>
                <div>
                  <h4 class="font-medium">Save Results</h4>
                  <p class="text-sm text-muted-foreground">Your scan will be automatically saved to your history</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Navigation Links -->
        <div class="mt-8 flex justify-center space-x-4">
          <a
            href="/"
            class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2"
          >
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
              ></path>
            </svg>
            Home
          </a>
          <a
            href="/history"
            class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2"
          >
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
              ></path>
            </svg>
            View History
          </a>
        </div>
      </div>
    </AuthGuard>
  </div>
</MainLayout>
