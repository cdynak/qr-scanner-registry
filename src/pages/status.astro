---
import Layout from '../layouts/Layout.astro';
import { testSupabaseConnection } from '../db/supabase';

let supabaseStatus = 'checking';
let errorMessage = '';

try {
  const isConnected = await testSupabaseConnection();
  supabaseStatus = isConnected ? 'connected' : 'disconnected';
} catch (error) {
  supabaseStatus = 'error';
  errorMessage = error.message;
}

const statusColor = {
  connected: 'text-green-600',
  disconnected: 'text-yellow-600', 
  error: 'text-red-600',
  checking: 'text-blue-600'
};

const statusIcon = {
  connected: '✅',
  disconnected: '⚠️',
  error: '❌',
  checking: '🔄'
};

const statusText = {
  connected: 'Connected',
  disconnected: 'Offline Mode',
  error: 'Connection Error',
  checking: 'Checking...'
};
---

<Layout title="System Status">
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8">System Status</h1>
    
    <div class="grid gap-6 md:grid-cols-2">
      <!-- Database Status -->
      <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold mb-4">Database Connection</h2>
        <div class="flex items-center space-x-3">
          <span class="text-2xl">{statusIcon[supabaseStatus]}</span>
          <div>
            <p class={`font-medium ${statusColor[supabaseStatus]}`}>
              {statusText[supabaseStatus]}
            </p>
            {supabaseStatus === 'disconnected' && (
              <p class="text-sm text-gray-600 mt-1">
                Running in offline mode with mock data
              </p>
            )}
            {supabaseStatus === 'error' && errorMessage && (
              <p class="text-sm text-red-500 mt-1">
                {errorMessage}
              </p>
            )}
          </div>
        </div>
      </div>

      <!-- Application Features -->
      <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold mb-4">Available Features</h2>
        <div class="space-y-3">
          <div class="flex items-center space-x-3">
            <span class="text-green-600">✅</span>
            <span>QR Code Scanning</span>
          </div>
          <div class="flex items-center space-x-3">
            <span class="text-green-600">✅</span>
            <span>Scan History (Local)</span>
          </div>
          <div class="flex items-center space-x-3">
            <span class={supabaseStatus === 'connected' ? 'text-green-600' : 'text-yellow-600'}>
              {supabaseStatus === 'connected' ? '✅' : '⚠️'}
            </span>
            <span>Cloud Sync {supabaseStatus !== 'connected' && '(Offline)'}</span>
          </div>
          <div class="flex items-center space-x-3">
            <span class={supabaseStatus === 'connected' ? 'text-green-600' : 'text-yellow-600'}>
              {supabaseStatus === 'connected' ? '✅' : '⚠️'}
            </span>
            <span>User Authentication {supabaseStatus !== 'connected' && '(Mock)'}</span>
          </div>
        </div>
      </div>

      <!-- System Information -->
      <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold mb-4">System Information</h2>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-600">Environment:</span>
            <span>{import.meta.env.MODE}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Build:</span>
            <span>v1.0.0</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Last Updated:</span>
            <span>{new Date().toLocaleDateString()}</span>
          </div>
        </div>
      </div>

      <!-- Troubleshooting -->
      <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold mb-4">Troubleshooting</h2>
        {supabaseStatus !== 'connected' && (
          <div class="space-y-3 text-sm">
            <p class="text-gray-700">
              The application is running in offline mode. Your scans are being saved locally.
            </p>
            <div class="bg-blue-50 border border-blue-200 rounded p-3">
              <p class="text-blue-800 font-medium">What this means:</p>
              <ul class="list-disc list-inside text-blue-700 mt-1 space-y-1">
                <li>All features work normally</li>
                <li>Data is stored locally in your browser</li>
                <li>No cloud backup until connection is restored</li>
              </ul>
            </div>
            <div class="bg-yellow-50 border border-yellow-200 rounded p-3">
              <p class="text-yellow-800 font-medium">To restore cloud features:</p>
              <ul class="list-disc list-inside text-yellow-700 mt-1 space-y-1">
                <li>Check your internet connection</li>
                <li>Try refreshing the page</li>
                <li>Contact support if the issue persists</li>
              </ul>
            </div>
          </div>
        )}
        {supabaseStatus === 'connected' && (
          <div class="text-green-700 bg-green-50 border border-green-200 rounded p-3">
            <p class="font-medium">✅ All systems operational</p>
            <p class="text-sm mt-1">Cloud sync and authentication are working normally.</p>
          </div>
        )}
      </div>
    </div>

    <div class="mt-8 text-center">
      <a 
        href="/" 
        class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
      >
        ← Back to Home
      </a>
    </div>
  </div>
</Layout>